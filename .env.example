# ===== LLM =====
# provider: gemini | openai | anthropic
LLM_PROVIDER=openai
LLM_MODEL=gpt-4.1-mini
LLM_TEMPERATURE=0.1

# ===== Embedding =====
# openai:    text-embedding-3-small | text-embedding-3-large
# gemini:    gemini-embedding-001
DENSE_MODEL=text-embedding-3-small
SPARSE_MODEL=Qdrant/bm25

# ===== Qdrant =====
QDRANT_URL=http://qdrant:6333

# ===== Agent =====
MAX_EXECUTE_TOOL_COUNT=3

# ===== vLLM / SGLang (온프레미스 LLM 서버) =====
# OpenAI 호환 서버 사용 시 아래 설정. 미설정 시 기본 OpenAI 사용.
# OPENAI_BASE_URL=http://내부서버:8000/v1

# ===== Notion =====
NOTION_TOKEN=
NOTION_DATABASE_ID=
# NOTION_PAGE_IDS=id1,id2

# ===== Confluence =====
CONFLUENCE_URL=https://your-domain.atlassian.net
CONFLUENCE_USERNAME=your@email.com
CONFLUENCE_API_TOKEN=
CONFLUENCE_SPACE_KEY=

# ===== OneDrive =====
ONEDRIVE_CLIENT_ID=
ONEDRIVE_CLIENT_SECRET=
ONEDRIVE_TENANT_ID=
ONEDRIVE_FOLDER_PATH=/

# ===== API Keys =====
GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ===== Access Control =====
# key → roles 매핑 (JSON). role에 "all" 포함 시 공개 문서 접근 가능.
# 예시: API_KEYS={"my-secret-key": ["hr", "all"], "finance-key": ["finance", "all"]}
API_KEYS={}

# ===== MCP =====
# 외부 MCP 클라이언트 연결 시 아래와 같이 설정:
# {
#   "mcpServers": {
#     "company-kb": {
#       "url": "http://localhost:8000/mcp",
#       "headers": { "Authorization": "Bearer my-secret-key" }
#     }
#   }
# }
