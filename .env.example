# ===== LLM =====
# provider: gemini | openai | anthropic
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.0-flash
LLM_TEMPERATURE=0.1

# ===== Embedding =====
DENSE_MODEL=gemini-embedding-001
SPARSE_MODEL=Qdrant/bm25

# ===== Qdrant =====
QDRANT_URL=http://qdrant:6333

# ===== Agent =====
MAX_EXECUTE_TOOL_COUNT=3

# ===== Notion =====
NOTION_TOKEN=
NOTION_DATABASE_ID=
# NOTION_PAGE_IDS=id1,id2

# ===== Confluence =====
CONFLUENCE_URL=https://your-domain.atlassian.net
CONFLUENCE_USERNAME=your@email.com
CONFLUENCE_API_TOKEN=
CONFLUENCE_SPACE_KEY=

# ===== OneDrive =====
ONEDRIVE_CLIENT_ID=
ONEDRIVE_CLIENT_SECRET=
ONEDRIVE_TENANT_ID=
ONEDRIVE_FOLDER_PATH=/

# ===== API Keys =====
GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
